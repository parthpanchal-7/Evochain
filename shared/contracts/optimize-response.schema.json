{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evochain.local/contracts/optimize-response.schema.json",
  "title": "OptimizationResponse",
  "type": "object",
  "required": [
    "node_id",
    "generated_at",
    "forecast",
    "decision",
    "simulation_status"
  ],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "forecast": {
      "type": "object",
      "required": ["predicted_mempool_size", "predicted_load", "trend"],
      "properties": {
        "predicted_mempool_size": {
          "type": "integer",
          "minimum": 0
        },
        "predicted_load": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "trend": {
          "type": "string"
        }
      }
    },
    "decision": {
      "type": "object",
      "required": ["block_size", "gas_price", "confidence", "rationale"],
      "properties": {
        "block_size": {
          "type": "integer",
          "minimum": 1
        },
        "gas_price": {
          "type": "integer",
          "minimum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "simulation_status": {
      "type": "string"
    }
  }
}

